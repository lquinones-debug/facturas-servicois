# Copiá este archivo a  secrets.toml  y completá los valores.
# secrets.toml NO se sube a git (está en .gitignore).
#
# En Streamlit Cloud: pegá este mismo contenido en Settings > Secrets.

sheets_id = "PEGAR_AQUI_EL_ID_DEL_GOOGLE_SHEET"
app_password = "PEGAR_LA_CLAVE_DEL_EQUIPO"   # clave de acceso del equipo (no la subas al repo)
# ID de la Unidad Compartida (Shared Drive) donde se guardan los adjuntos.
# La cuenta de servicio (client_email de abajo) debe ser MIEMBRO de esa Unidad.
drive_folder_id = "PEGAR_AQUI_EL_ID_DE_LA_UNIDAD_COMPARTIDA"

[gcp_service_account]
type = "service_account"
project_id = "tiendabot-494700"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "tiendabot-sheets@tiendabot-494700.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
